<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Motherhood IVF | Premium Blog Layout</title>
  <style>
    :root {
      --primary: #008080; /* Brand Teal */
      --secondary: #e91e63; /* Brand Pink */
      --dark: #2c3e50;
      --light-gray: #f8f9fa;
      --border: #eaedef;
      --transition: all 0.3s ease;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      margin: 0;
      color: var(--dark);
      line-height: 1.8;
      background-color: #fff;
    }

    /* Navigation */
    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 5%;
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      z-index: 1000;
    }
    .logo-text { font-weight: 800; font-size: 1.4rem; color: var(--primary); text-decoration: none; }
    .nav-links a { text-decoration: none; color: var(--dark); margin-left: 20px; font-weight: 500; font-size: 0.9rem; }

    /* Layout Container */
    .main-wrapper {
      max-width: 1250px;
      margin: 0 auto;
      padding: 2rem 5%;
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 50px;
    }

    /* Breadcrumbs */
    .breadcrumb { font-size: 0.85rem; margin-bottom: 1.5rem; color: #888; }
    .breadcrumb a { color: var(--primary); text-decoration: none; }

    /* FIXED FRAME BLOG IMAGE */
    .feature-image-frame {
      width: 100%;
      aspect-ratio: 16 / 7;
      background-color: #eee;
      border-radius: 16px;
      overflow: hidden;
      margin-bottom: 25px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }
    .feature-image-frame img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: var(--transition);
    }

    /* Social Icons */
    .social-top { display: flex; gap: 12px; margin-bottom: 20px; }
    .social-btn {
      width: 36px; height: 36px; border-radius: 50%;
      background: var(--light-gray); display: flex;
      align-items: center; justify-content: center;
      text-decoration: none; font-size: 0.8rem; color: var(--dark);
      border: 1px solid var(--border);
    }

    /* Author Section */
    .author-bar {
      display: flex;
      align-items: center;
      gap: 15px;
      margin: 20px 0 40px;
      padding: 15px 0;
      border-bottom: 1px solid var(--border);
    }
    .author-img { width: 45px; height: 45px; border-radius: 50%; object-fit: cover; }
    .author-link { font-weight: 700; color: var(--secondary); text-decoration: none; }

    /* Content Body */
    .content h2 { color: var(--primary); margin-top: 2.5rem; margin-bottom: 1rem; }
    .content p { margin-bottom: 1.5rem; }
    
    /* Responsive CTA */
    .content-cta {
      background: linear-gradient(135deg, #f0fdfa 0%, #fff 100%);
      border: 1px solid #ccf2f4;
      border-radius: 20px;
      display: flex;
      overflow: hidden;
      margin: 50px 0;
      align-items: center;
    }
    .content-cta img { width: 45%; height: 280px; object-fit: cover; }
    .cta-body { padding: 30px; }
    .btn-main {
      background: var(--secondary); color: white;
      padding: 12px 25px; border-radius: 8px;
      text-decoration: none; font-weight: 600; display: inline-block;
      transition: var(--transition);
      border: none;
    }
    .btn-main:hover { opacity: 0.9; transform: translateY(-2px); }

    /* Doctor Card */
    .doctor-card {
      background: var(--light-gray);
      border-radius: 24px;
      padding: 40px;
      margin-top: 60px;
      display: flex;
      gap: 30px;
    }
    .doc-avatar { width: 140px; height: 140px; border-radius: 20px; object-fit: cover; }
    .doc-btns { display: flex; gap: 15px; margin-top: 20px; }
    .btn-outline { border: 1px solid var(--primary); color: var(--primary); background: transparent; }

    /* Recent Blogs Grid */
    .recent-section { margin-top: 80px; }
    .blog-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 25px;
      margin-top: 30px;
    }
    .small-card { border-radius: 12px; overflow: hidden; border: 1px solid var(--border); }
    .small-card img { width: 100%; height: 160px; object-fit: cover; }
    .small-card-pad { padding: 15px; }

    /* Sidebar Widgets */
    .sidebar { position: sticky; top: 100px; height: fit-content; }
    .widget { margin-bottom: 40px; }
    .widget h4 { font-size: 1.1rem; border-bottom: 2px solid var(--secondary); display: inline-block; margin-bottom: 20px; }
    .widget ul { list-style: none; padding: 0; }
    .widget li { margin-bottom: 12px; }
    .widget li a { 
      text-decoration: none; color: var(--dark); 
      display: flex; justify-content: space-between; 
      font-size: 0.95rem; padding: 5px 0;
      transition: var(--transition);
    }
    .widget li a:hover { color: var(--primary); }
    .count { background: #eee; padding: 2px 8px; border-radius: 20px; font-size: 0.75rem; }

    /* Responsive Design */
    @media (max-width: 900px) {
      .main-wrapper { grid-template-columns: 1fr; }
      .blog-grid { grid-template-columns: 1fr 1fr; }
      .content-cta { flex-direction: column; }
      .content-cta img { width: 100%; height: 200px; }
    }
  </style>
</head>
